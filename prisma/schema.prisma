generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Organization {
  id           String        @id @default(cuid())
  name         String
  dailyTarget  Float         @default(0)
  services     Service[]
  customers    Customer[]
  staff        Staff[]
  users        User[]
  appointments Appointment[]
  Package      Package[]
}

model Service {
  id              String           @id @default(cuid())
  name            String
  durationMinutes Int
  price           Decimal
  color           String?          @default("#3788d8") // Couleur par défaut (bleu FullCalendar)
  organizationId  String
  organization    Organization     @relation(fields: [organizationId], references: [id])
  appointments    Appointment[]
  PackageService  PackageService[]
}

model Customer {
  id              String            @id @default(cuid())
  firstName       String
  lastName        String
  Note            String?
  phone           String
  organizationId  String
  organization    Organization      @relation(fields: [organizationId], references: [id])
  appointments    Appointment[]
  CustomerPackage CustomerPackage[]
  createdAt         DateTime         @default(now())
  updatedAt        DateTime @default(now())        @updatedAt
}

model Staff {
  id             String        @id @default(cuid())
  firstName      String
  lastName       String
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  appointments   Appointment[]
}

/// Appointment: startTime, endTime (calculé), relations obligatoires et organizationId pour isolation
model Appointment {
  id                String           @id @default(cuid())
  title             String?
  startTime         DateTime
  endTime           DateTime
  duration          Int
  note              String?
  status            String           @default("CONFIRMED") // CONFIRMED, PAID, CANCELLED
  finalPrice        Float?           // Le prix total payé (Base + Extras)
  price             Decimal          @default(0)
  startDate         String?
  paymentMethod     String?          // CB, Espèces, Chèque
  extras        String?
  customerPackageId String?
  customerPackage   CustomerPackage? @relation(fields: [customerPackageId], references: [id])
  serviceId         String
  service           Service          @relation(fields: [serviceId], references: [id])
  customerId        String
  customer          Customer         @relation(fields: [customerId], references: [id])
  staffId           String?
  staff             Staff?            @relation(fields: [staffId], references: [id])
  organizationId    String
  organization      Organization     @relation(fields: [organizationId], references: [id])
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([organizationId, startTime])
}

model Package {
  id               String            @id @default(cuid())
  name             String
  price            Float
  description      String?
  organizationId   String
  organization     Organization      @relation(fields: [organizationId], references: [id])
  packageServices  PackageService[]
  customerPackages CustomerPackage[]
}

model PackageService {
  id        String  @id @default(cuid())
  packageId String
  serviceId String
  quantity  Int
  package   Package @relation(fields: [packageId], references: [id])
  service   Service @relation(fields: [serviceId], references: [id])
}

model CustomerPackage {
  id                String        @id @default(cuid())
  customerId        String
  packageId         String
  totalSessions     Int
  sessionsRemaining Int
  buyDate           DateTime      @default(now())
  expiresAt         DateTime?
  customer          Customer      @relation(fields: [customerId], references: [id])
  package           Package       @relation(fields: [packageId], references: [id])
  appointments      Appointment[]
}

/// NextAuth models (Prisma Adapter)
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  hashedPassword String?
  role          String    @default("USER")
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  emailVerified DateTime?
  image         String?
  // application specific relations
  // optionally link user to organization if needed
  // organizationId String?
  // organization   Organization? @relation(fields: [organizationId], references: [id])
  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id])

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id     String   @id @default(cuid())
  email  String   @unique
  token  String   @unique
  expires DateTime
}

