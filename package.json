{
  "name": "independance",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm exec prisma generate && pnpm exec prisma db seed && next dev",
    "seed": "pnpm exec prisma db seed",
    "create-admin": "ts-node --compiler-options '{\"module\":\"CommonJS\"}' scripts/create-admin.ts",
    "check-env": "node ./scripts/check-nextauth-secret.js",
    "prebuild": "pnpm run check-env && prisma generate && (mv src/middleware.ts src/_middleware_disabled.ts || true)",
    "build": "next build",
    "prestart": "pnpm run check-env",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest"
  },
  "prisma": {
    "seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^1.6.0",
    "@fullcalendar/common": "^5.11.5",
    "@fullcalendar/core": "^5.11.5",
    "@fullcalendar/daygrid": "^5.11.5",
    "@fullcalendar/interaction": "^5.11.5",
    "@fullcalendar/react": "^5.11.5",
    "@fullcalendar/resource-timegrid": "^5.11.5",
    "@fullcalendar/timegrid": "^5.11.5",
    "@prisma/client": "^4.16.2",
    "@radix-ui/react-dialog": "^1.0.6",
    "bcryptjs": "^2.4.3",
    "date-fns": "^4.1.0",
    "decimal.js": "^10.6.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.268.0",
    "next": "16.2.1",
    "next-auth": "5.0.0-beta.30",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "resend": "^6.9.4",
    "sonner": "^2.0.7",
    "tippy.js": "^6.3.7",
    "zod": "^3.22.2"
  },
  "resend": {
    "version": "1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "4.1.2",
    "autoprefixer": "^10.4.27",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "prisma": "^4.16.2",
    "tailwindcss": "^4.2.2",
    "ts-node": "^10.9.1",
    "typescript": "^5",
    "vitest": "^4.1.2"
  }
}
