# Exemple de fichier d'environnement (NE PAS committer de vrais secrets)
# Copie ce fichier en `.env.local` et remplis les valeurs sensibles avant de lancer l'application

# URL de connexion à la base (utiliser le pooler Neon pour la production/ runtime)
# Exemple (remplace <PASSWORD> par le mot de passe réel) :
# DATABASE_URL="postgresql://neondb_owner:<PASSWORD>@ep-rough-king-algpzdq3-pooler.c-3.eu-central-1.aws.neon.tech:5432/neondb?sslmode=require&pgbouncer=true"

# Si tu utilises un Shadow DB pour les migrations Prisma :
# SHADOW_DATABASE_URL="postgresql://neondb_owner:<PASSWORD>@ep-rough-king-algpzdq3-pooler.c-3.eu-central-1.aws.neon.tech:5432/neondb_shadow?sslmode=require&pgbouncer=true"

# Secret pour NextAuth / Auth.js
# Dans ton CI/Production utilise une valeur générée : openssl rand -hex 32
# NEXTAUTH_SECRET=change_me_generate_a_secure_value

# Optionnel : URL d'API d'envoi d'emails (Resend par ex.)
# RESEND_API_KEY=xxxx

# Ne pas committer `.env.local` — .gitignore contient déjà .env*

