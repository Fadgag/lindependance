# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — ne jamais committer les vrais secrets
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local
# .env.example est autorisé (template sans secrets)

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Prisma - ne jamais commiter la base de données locale
prisma/*.db
prisma/*.db-journal
prisma/*.db-wal
prisma/*.db-shm

# Logs & PIDs dev server
build.log
.dev_server.log
.dev_server.pid
.devserver.log
.devserver.pid
*.log

# IDE JetBrains
.idea/

# Scripts temporaires
tmp_*.js


# Debug scripts (generated locally)
scripts/checkAppointments.js
psql
